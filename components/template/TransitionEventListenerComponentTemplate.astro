---
export interface Props {}
const TAG = 'vtbot-some-tag'; // see also start of script
---

<meta name={TAG} content="true" />

<script>
import { TransitionBeforeSwapEvent } from "astro:transitions/client";

	const TAG = 'vtbot-some-tag';

	const enabled = () => !!document.querySelector(`meta[name="${TAG}"]`);

	const beforeSwap = (event: TransitionBeforeSwapEvent) => {
		if (enabled()) {
		}
	};

	document.addEventListener('astro:before-swap', beforeSwap);
</script>
